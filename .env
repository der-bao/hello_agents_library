# ================================
# 1. 大语言模型 (LLM) 配置
# ================================
# 当前使用阿里云 DashScope 兼容模式提供大模型服务
LLM_API_KEY="sk-221b63475fbe44a6b3d6bd46b4f84c35"           # LLM API 密钥
LLM_MODEL_ID="qwen3-max"                                   # 使用的模型 ID (如 Qwen)
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1" # OpenAI兼容的API基础路径

# ================================
# 2. 外部工具和服务配置 (Tools)
# ================================
# SerpApi: 用于 Agent 进行联网搜索，获取 Google 搜索结果
SERPAPI_API_KEY="83785728de395d18796c65ed1333fbd751ec0afeeb538ae73ac19030a667ca1e"

# ================================
# 3. 向量数据库 (Qdrant) 配置
# ================================
# Qdrant：开源高性能向量数据库，主要用于存储嵌入向量、执行相似度查询（RAG等）
# 获取云服务及API密钥：https://cloud.qdrant.io/

# --- 使用本地 Qdrant (需使用 Docker 部署，当前开启) ---
# 本地开发模式通常为空，无需 API Key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- 使用 Qdrant 云服务 (推荐用于生产环境，取消注释即可启用) ---
# QDRANT_URL=https://ea0ab538-615c-45a1-bbda-4e62446a4694.us-east4-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.OJtDf3XuKmRMOGnfAa49xN6vnJVWrSz-dTarPWEl4oo

# --- Qdrant 集合 (Collection) 基础参数设置 ---
QDRANT_COLLECTION=hello_agents_vectors                     # 默认使用的 Collection 名称
QDRANT_VECTOR_SIZE=384                                     # 向量维度大小 (需与下方的Embedding模型输出维度对齐，如不一致会报错)
QDRANT_DISTANCE=cosine                                     # 距离度量方式: cosine(余弦)、dot(内积)、euclidean(欧氏距离)
QDRANT_TIMEOUT=30                                          # API 请求超时时间(秒)

# ================================
# 4. 图数据库 (Neo4j) 配置 
# ================================
# Neo4j：图数据库，用于存储实体关系、构建知识图谱 (Knowledge Graph)
# 需要与 docker-compose.yml 里的 NEO4J_AUTH 保持一致

# --- Neo4j 基础连接 ---
NEO4J_URI=bolt://localhost:7687                            # Bolt 协议连接地址 (本地Docker默认7687)
NEO4J_USERNAME=neo4j                                       # Neo4j 用户名（默认 neo4j）
NEO4J_PASSWORD=hello-agents-password                       # Neo4j 密码 (需与代码库和部署文件统一)

# --- Neo4j 连接池高级配置 ---
NEO4J_DATABASE=neo4j                                       # 默认数据库名称
NEO4J_MAX_CONNECTION_LIFETIME=3600                         # 最大连接存活时间 (秒)
NEO4J_MAX_CONNECTION_POOL_SIZE=50                          # 最大连接池数量上限
NEO4J_CONNECTION_TIMEOUT=60                                # 连接获取超时时间 (秒)

# ================================
# 5. 文本嵌入模型 (Embedding) 配置
# ================================
# Embedding 模型负责将文本转化为向量，用于存入向量数据库
# 当前采用阿里云的 Embedding 模型

EMBED_MODEL_TYPE=dashscope                                 # 使用的模型提供商/平台类型
EMBED_MODEL_NAME=text-embedding-v3                         # 具体的 Embedding 模型名称 (例如阿里云的 text-embedding-v3)
EMBED_API_KEY=sk-221b63475fbe44a6b3d6bd46b4f84c35          # 模型服务 API 密钥
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 # 模型服务请求的基础路径
